<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="600.0"
		   prefWidth="950.0"
		   stylesheets="@/application/application.css" xmlns="http://javafx.com/javafx/8"
		   fx:controller="controllers.MenuController">
    <children>
        <Pane id="menu" prefHeight="200.0" prefWidth="200.0">
            <children>
                <Pane id="logo" layoutX="53.0" layoutY="57.0"
                      prefHeight="150.0" prefWidth="300.0"/>
            </children>
        </Pane>
        <Button id="raised-button" contentDisplay="CENTER"
                mnemonicParsing="false" onAction="#about" prefHeight="50.0"
                prefWidth="200.0" text="ABOUT" textAlignment="CENTER"
                StackPane.alignment="BOTTOM_LEFT">
            <font>
                <Font name="System Bold" size="17.0"/>
            </font>
            <StackPane.margin>
                <Insets bottom="260.0" left="50.0" right="50.0" top="50.0"/>
            </StackPane.margin>
        </Button>
        <Button id="raised-button" cancelButton="true"
                mnemonicParsing="false" onAction="#exit" prefHeight="50.0"
                prefWidth="200.0" text="EXIT" textAlignment="CENTER"
                StackPane.alignment="BOTTOM_LEFT">
            <font>
                <Font name="System Bold" size="17.0"/>
            </font>
            <StackPane.margin>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
            </StackPane.margin>
        </Button>
        <Button id="raised-button" mnemonicParsing="false"
                onAction="#play" prefHeight="50.0" prefWidth="200.0" text="PLAY"
                textAlignment="CENTER" StackPane.alignment="BOTTOM_LEFT">
            <font>
                <Font name="System Bold" size="17.0"/>
            </font>
            <StackPane.margin>
                <Insets bottom="120.0" left="50.0"/>
            </StackPane.margin>
        </Button>
        <Button id="raised-button" mnemonicParsing="false"
                onAction="#instructions" prefHeight="50.0" prefWidth="200.0"
                text="INSTRUCTIONS" StackPane.alignment="BOTTOM_LEFT">
            <font>
                <Font name="Calibri Bold" size="17.0"/>
            </font>
            <StackPane.margin>
                <Insets bottom="190.0" left="50.0"/>
            </StackPane.margin>
        </Button>
    </children>
</StackPane>
